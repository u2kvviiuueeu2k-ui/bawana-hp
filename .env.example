# MongoDB Atlas 接続文字列
# 例: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/bawana?retryWrites=true&w=majority

# MongoDB データベース名
MONGODB_DB=bawana

# 通知メール送信先（将来の問い合わせ通知用）
NOTIFY_EMAIL=owner@example.com

# 本番環境フラグ（Vercel が自動でセット）
# NODE_ENV=production
